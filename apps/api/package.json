{
  "name": "@triforge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "corepack pnpm --filter @triforge/shared build && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "corepack pnpm --filter @triforge/shared build && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@triforge/shared": "workspace:*",
    "fastify": "^5.8.5",
    "pg": "^8.13.1",
    "zod": "^3.25.57"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
