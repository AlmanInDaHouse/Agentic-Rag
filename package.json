{
  "name": "triforge-agentic-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "corepack pnpm -r build",
    "test": "corepack pnpm -r --if-present test && corepack pnpm test:retrieval-eval && corepack pnpm test:code-graph-scanner",
    "test:harness": "corepack pnpm --filter @triforge/shared build && vitest --config tooling/harness/vitest.config.ts",
    "test:retrieval-eval": "vitest --config tooling/retrieval-eval/vitest.config.ts",
    "test:code-graph-scanner": "vitest --config tooling/code-graph-scanner/vitest.config.ts",
    "code-graph:scan": "corepack pnpm --filter @triforge/api exec tsx ../../tooling/code-graph-scanner/src/runner.ts --repo-root ../..",
    "code-graph:check": "corepack pnpm --filter @triforge/api exec tsx ../../tooling/code-graph-scanner/src/check.ts",
    "code-graph:pack": "corepack pnpm --filter @triforge/api exec tsx ../../tooling/code-graph-scanner/src/pack.ts --repo-root ../..",
    "code-graph:pack:check": "corepack pnpm --filter @triforge/api exec tsx ../../tooling/code-graph-scanner/src/packCheck.ts",
    "code-graph:pack:eval": "corepack pnpm --filter @triforge/api exec tsx ../../tooling/code-graph-scanner/src/packEval.ts",
    "code-graph:ingest": "corepack pnpm --filter @triforge/api exec tsx ../../tooling/code-graph-scanner/src/ingest.ts --repo-root ../..",
    "eval:retrieval": "corepack pnpm --filter @triforge/api exec tsx ../../tooling/retrieval-eval/src/runner.ts",
    "eval:retrieval:gate": "corepack pnpm --filter @triforge/api exec tsx ../../tooling/retrieval-eval/src/runner.ts --gate --thresholds tooling/retrieval-eval/baselines/thresholds.v1.json --out reports/retrieval-eval/latest.json",
    "harness:mvp": "corepack pnpm --filter @triforge/shared build && vitest --config tooling/harness/vitest.config.ts tooling/harness/src/scenarios/mvpDebate.scenario.ts",
    "typecheck": "corepack pnpm --filter @triforge/shared build && corepack pnpm -r --if-present typecheck",
    "dev": "corepack pnpm -r --parallel --filter @triforge/api --filter @triforge/web dev",
    "dev:api": "corepack pnpm --filter @triforge/api dev",
    "dev:web": "corepack pnpm --filter @triforge/web dev",
    "db:migrate": "corepack pnpm --filter @triforge/api db:migrate",
    "lint:deps": "node scripts/check-dependencies.mjs",
    "deps:audit": "corepack pnpm audit",
    "deps:outdated": "corepack pnpm outdated -r"
  },
  "engines": {
    "node": ">=20.11"
  },
  "devDependencies": {
    "@triforge/shared": "workspace:*",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "vitest": "^4.1.8"
  }
}
